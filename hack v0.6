                                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                    commandFound = true
                                    if hrp then hrp.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3) end
                                    break
                                end
                            end
                        end
                    end
                
                elseif cmd == "hb" then
                    local size = tonumber(args[2])
                    if size then
                        hitboxSize = size
                        commandFound = true
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                p.Character.HumanoidRootPart.Size = Vector3.new(size, size, size)
                                p.Character.HumanoidRootPart.Transparency = size > 2 and 0.7 or 0
                                p.Character.HumanoidRootPart.CanCollide = false
                            end
                        end
                    else
                        errorMessage = "falta un numero."
                    end
                elseif cmd == "unhb" then
                    commandFound = true
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 2)
                            p.Character.HumanoidRootPart.Transparency = 0
                            p.Character.HumanoidRootPart.CanCollide = true
                        end
                    end
                elseif cmd == "aimbot" or cmd == "camlock" then
                    commandFound = true
                    if not aimbotActive then
                        aimbotActive = true
                        aimbotConnection = RunService.RenderStepped:Connect(function()
                            local target = getClosestPlayerToMouse()
                            if target and target.Character and target.Character:FindFirstChild("Head") then
                                local targetCFrame = CFrame.new(Camera.CFrame.Position, target.Character.Head.Position)
                                Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 0.25)
                            end
                        end)
                    end
                elseif cmd == "unaimbot" or cmd == "uncamlock" then
                    commandFound = true
                    if aimbotActive then
                        aimbotActive = false
                        if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
                    end
                elseif cmd == "spin" then
                    local speed = tonumber(args[2])
                    if speed then
                        if hrp then
                            if hrp:FindFirstChild("SpinBotVelocity") then hrp.SpinBotVelocity:Destroy() end
                            spinbotActive = true
                            spinVelocity = Instance.new("BodyAngularVelocity")
                            spinVelocity.Name = "SpinBotVelocity"
                            spinVelocity.MaxTorque = Vector3.new(0, math.huge, 0)
                            spinVelocity.AngularVelocity = Vector3.new(0, speed, 0)
                            spinVelocity.Parent = hrp
                            commandFound = true
                        end
                    else
                        errorMessage = "falta un numero."
                    end
                elseif cmd == "unspin" then
                    commandFound = true
                    spinbotActive = false
                    if hrp and hrp:FindFirstChild("SpinBotVelocity") then
                        hrp.SpinBotVelocity:Destroy()
                    end
                elseif cmd == "chatspam" then
                    commandFound = true
                    local message = cleanCommandString:sub(10)
                    if message == "" then message = "c00lgui Legacy running" end
                    if chatSpamActive then chatSpamActive = false end
                    task.wait(0.1)
                    chatSpamActive = true
                    chatSpamTask = task.spawn(function()
                        while chatSpamActive do
                            local bypassStr = message .. " [" .. tostring(math.random(100,999)) .. "]"
                            local textChannel = game:GetService("TextChatService"):FindFirstChild("TextChannels") and game:GetService("TextChatService").TextChannels:FindFirstChild("RBXGeneral")
                            if textChannel then textChannel:SendAsync(bypassStr)
                            else
                                local chatEvent = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents") and game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
                                if chatEvent then chatEvent:FireServer(bypassStr, "All") end
                            end
                            task.wait(0.7)
                        end
                    end)
                elseif cmd == "unchatspam" then
                    commandFound = true
                    chatSpamActive = false
                elseif cmd == "keybind" then
                    commandFound = true
                    local cmdToBind = args[2]
                    local keyStr = args[3] and args[3]:upper()
                    if cmdToBind and keyStr then
                        local success, keyCode = pcall(function() return Enum.KeyCode[keyStr] end)
                        if success and keyCode then
                            keybinds[keyCode] = ";" .. cmdToBind .. ";"
                        end
                    end
                elseif cmd == "clearbinds" then
                    commandFound = true
                    table.clear(keybinds)

                elseif cmd == "gravity" or cmd == "grav" then
                    local targetGrav = tonumber(args[2])
                    if targetGrav then
