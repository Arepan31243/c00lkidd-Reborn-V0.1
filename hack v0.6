                    local cap = tonumber(args[2])
                    if cap and setfpscap then
                        commandFound = true
                        setfpscap(cap)
                    else
                        errorMessage = "falta un numero."
                    end
                
                elseif cmd == "serverhop" or cmd == "sh" then
                    commandFound = true
                    local servers = {}
                    local reqUrl = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
                    local ok, res = pcall(function() return HttpService:JSONDecode(game:HttpGet(reqUrl)) end)
                    if ok and res and res.data then
                        for _, server in ipairs(res.data) do
                            if type(server) == "table" and server.id ~= game.JobId and server.playing < server.maxPlayers and server.playing > 2 then
                                table.insert(servers, server.id)
                            end
                        end
                        if #servers > 0 then
                            local queue = queue_on_teleport or (syn and syn.queue_on_teleport)
                            if queue and getgenv().c00l_raw then queue(getgenv().c00l_raw) end
                            TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
                        end
                    end
                elseif cmd == "camfov" then
                    local targetFov = tonumber(args[2])
                    if targetFov then
                        commandFound = true
                        TweenService:Create(Camera, TweenInfo.new(0.2), {FieldOfView = targetFov}):Play()
                    else
                        errorMessage = "falta un numero."
                    end
                elseif cmd == "stats" then
                    commandFound = true
                    if statsActive then stopStats() else startStats() end
                end
            end
        else errorMessage = "requiere ; para su función." end
    else errorMessage = "comando inexistente." end
    
    return commandFound, errorMessage, cleanCommandString
end

CmdBar.FocusLost:Connect(function(enterPressed)
    if not enterPressed or CmdBar.Text == "" or ConfirmFrame.Visible then return end
    
    local commandFound, errorMessage, cleanCommandString = executeCommand(CmdBar.Text)
    
    if commandFound then
        addLog(cleanCommandString)
        CmdBar.BorderColor3 = Color3.fromRGB(0, 255, 100)
        CmdBar.PlaceholderText = "escribe tu comando."
        spawnSuccessPopup() 
    else
        CmdBar.BorderColor3 = Color3.fromRGB(255, 0, 0)
        CmdBar.PlaceholderText = errorMessage
        spawnErrorPopup(errorMessage)
    end
    task.delay(0.4, function() CmdBar.BorderColor3 = Color3.fromRGB(100, 0, 20) end)
    CmdBar.Text = ""
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Semicolon then
        if minimized then setMinimizedState(false) end
        task.wait()
        CmdBar:CaptureFocus()
        CmdBar.Text = "" 
    elseif keybinds[input.KeyCode] then
        local commandFound = executeCommand(keybinds[input.KeyCode])
        if commandFound then spawnSuccessPopup() end
    end
end)

