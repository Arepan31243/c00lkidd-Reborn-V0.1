local VALID_COMMANDS = {
    ["speed"] = true, ["jumppower"] = true, ["jpower"] = true, ["fly"] = true, ["unfly"] = true, 
    ["freecam"] = true, ["fc"] = true, ["unfreecam"] = true, ["unfc"] = true,
    ["fling"] = true, ["esp"] = true, ["unesp"] = true,
    ["view"] = true, ["unview"] = true,
    ["infinitejump"] = true, ["infjump"] = true, ["uninfinitejump"] = true, ["uninfjump"] = true,
    ["tp"] = true, ["rejoin"] = true, ["rj"] = true, ["btools"] = true,
    ["noclip"] = true, ["unnoclip"] = true,
    ["fullbright"] = true, ["unfullbright"] = true, ["fb"] = true, ["unfb"] = true,
    ["nofog"] = true, ["unnofog"] = true, ["nf"] = true, ["unnf"] = true,
    ["clicktp"] = true, ["ctp"] = true, ["unclicktp"] = true, ["unctp"] = true,
    ["hb"] = true, ["unhb"] = true, ["aimbot"] = true, ["camlock"] = true, ["unaimbot"] = true,
    ["spin"] = true, ["unspin"] = true,
    ["chatspam"] = true, ["unchatspam"] = true, ["keybind"] = true, ["clearbinds"] = true,
    ["gravity"] = true, ["ungravity"] = true, ["antiafk"] = true, ["noidle"] = true, ["unantiafk"] = true,
    ["fpscap"] = true, ["serverhop"] = true, ["sh"] = true, ["camfov"] = true, ["stats"] = true
}

local function executeCommand(rawTextString)
    if rawTextString == "" or ConfirmFrame.Visible then return false, "error", "" end
    
    local cleanedRaw = string.gsub(rawTextString, "^%s*(.-)%s*$", "%1")
    local input = string.lower(cleanedRaw)
    
    local commandFound = false
    local errorMessage = "comando inexistente." 
    local hasSemicolon = false
    local cleanCommandString = input
    
    if string.sub(input, 1, 1) == ";" then
        hasSemicolon = true
        cleanCommandString = string.sub(input, 2)
    elseif string.sub(input, -1) == ";" then
        hasSemicolon = true
        cleanCommandString = string.sub(input, 1, -2)
    end
    
    cleanCommandString = string.gsub(cleanCommandString, "^%s*(.-)%s*$", "%1")
    local args = string.split(cleanCommandString, " ")
    local cmd = args[1]
    
    local isValidRejoin = (cmd == "rejoin" or cmd == "rj")
    local isOtherCommand = (not isValidRejoin) and VALID_COMMANDS[cmd]

    if isOtherCommand or isValidRejoin then
        if hasSemicolon then
            local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and hrp then
                if cmd == "speed" then
                    local amount = tonumber(args[2])
                    if amount then 
                        commandFound = true
                        hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0)
                        humanoid.WalkSpeed = amount 
                    else
                        errorMessage = "falta un numero."
                    end
                elseif cmd == "jumppower" or cmd == "jpower" then
                    local amount = tonumber(args[2])
                    if amount then 
                        commandFound = true
                        humanoid.UseJumpPower = true 
                        humanoid.JumpPower = amount 
                        humanoid.JumpHeight = amount / 3.5
                    else
                        errorMessage = "falta un numero."
                    end
                elseif cmd == "btools" then
                    commandFound = true
                    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
                    if backpack then
                        for i = 1, 3 do
                            local tool = Instance.new("HopperBin")
                            tool.BinType = i
                            tool.Parent = backpack
                        end
                    end
                elseif cmd == "rejoin" or cmd == "rj" then
                    commandFound = true
                    local queue = queue_on_teleport or (syn and syn.queue_on_teleport)
                    if queue and getgenv().c00l_raw then queue(getgenv().c00l_raw) end
                    game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer)
                
                elseif cmd == "esp" then commandFound = true; startESP()
                elseif cmd == "unesp" then commandFound = true; stopESP()

                elseif cmd == "view" then
                    local targetName = args[2]
                    if targetName then
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer then
                                local nameMatch = string.sub(string.lower(p.Name), 1, string.len(targetName)) == targetName
                                local dispMatch = p.DisplayName and (string.sub(string.lower(p.DisplayName), 1, string.len(targetName)) == targetName)
                                
                                if (nameMatch or dispMatch) then
                                    commandFound = true
                                    viewingPlayer = p
                                    if viewConnection then viewConnection:Disconnect() end
                                    
                                    viewConnection = RunService.RenderStepped:Connect(function()
                                        if viewingPlayer == p and p.Parent and p.Character then
                                            Camera.CameraType = Enum.CameraType.Custom
                                            local targetHum = p.Character:FindFirstChildOfClass("Humanoid")
                                            if targetHum and targetHum.Health > 0 then 
                                                Camera.CameraSubject = targetHum
                                            else
                                                Camera.CameraSubject = humanoid
                                            end
                                        else
                                            viewingPlayer = nil
                                            Camera.CameraSubject = humanoid
                                            if viewConnection then viewConnection:Disconnect(); viewConnection = nil end
                                        end
                                    end)
                                    break
                                end
                            end
                        end
                    end

                elseif cmd == "unview" then
                    commandFound = true
                    viewingPlayer = nil
                    if viewConnection then viewConnection:Disconnect(); viewConnection = nil end
                    Camera.CameraType = Enum.CameraType.Custom
                    Camera.CameraSubject = humanoid

                elseif cmd == "freecam" or cmd == "fc" then
                    commandFound = true
                    if not freecamActive then
                        freecamActive = true
                        if viewConnection then viewConnection:Disconnect(); viewConnection = nil end
                        viewingPlayer = nil
                        Camera.CameraType = Enum.CameraType.Scriptable
                        hrp.Anchored = true
                        
                        local p, y, r = Camera.CFrame:ToOrientation()
                        freecamPitch = p
                        freecamYaw = y
                        
                        freecamConnection = RunService.RenderStepped:Connect(function()
                            if not freecamActive then return end
                            if UserInputService:GetFocusedTextBox() then 
                                UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                                return 
                            end
                            
                            if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                                UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
                                local delta = UserInputService:GetMouseDelta()
                                freecamYaw = freecamYaw - math.rad(delta.X * 0.25)
                                freecamPitch = math.clamp(freecamPitch - math.rad(delta.Y * 0.25), -math.rad(85), math.rad(85))
                            else
                                UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                            end
                            Camera.CFrame = CFrame.new(Camera.CFrame.Position) * CFrame.fromOrientation(freecamPitch, freecamYaw, 0)
                            
                            local moveDir = Vector3.new(0, 0, 0)
                            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end
                            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
                            
                            if moveDir.Magnitude > 0 then
                                Camera.CFrame = Camera.CFrame + (moveDir.Unit * (flySpeed * 0.03))
                            end
                        end)
                    end

                elseif cmd == "unfreecam" or cmd == "unfc" then commandFound = true; stopFreecam()
                elseif cmd == "fling" then
                    local targetName = args[2]
                    if targetName then
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and string.sub(string.lower(p.Name), 1, string.len(targetName)) == targetName then
                                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                    commandFound = true
                                    local targetHrp = p.Character.HumanoidRootPart
                                    local oldCFrame = hrp.CFrame
                                    local bav = Instance.new("BodyAngularVelocity")
                                    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                                    bav.AngularVelocity = Vector3.new(0, 999999, 0)
                                    bav.Parent = hrp
                                    
                                    local startTime = os.clock()
                                    local flingLoop
                                    flingLoop = RunService.Heartbeat:Connect(function()
                                        if os.clock() - startTime > 1.5 or not hrp or not targetHrp or not targetHrp.Parent then
                                            if flingLoop then flingLoop:Disconnect() end
                                            if bav then bav:Destroy() end
                                            if hrp then
                                                hrp.CFrame = oldCFrame
                                                hrp.Velocity = Vector3.new(0,0,0)
                                                hrp.RotVelocity = Vector3.new(0,0,0)
                                            end
                                        else
